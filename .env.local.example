META_APP_ID=your_app_id
META_APP_SECRET=your_app_secret
META_API_VERSION=v25.0
NEXTAUTH_URL=http://localhost:3000
SESSION_SECRET=change_this_to_a_random_32_char_string
# Temporary email/password gate (lib/auth.ts) — comma-separated email:password pairs.
# No signup, no roles. Add/revoke users by editing this list; no redeploy needed on Vercel.
AUTH_USERS=love@pickrr.com:testpass123,client@brand.com:clientpass456

# Optional — internal activity log at /logs (lib/activity-log.ts). Every non-demo report
# fetch is POSTed to a Google Apps Script Web App URL that appends a row to a Sheet — free,
# no database. See docs/activity-log-setup.md for the exact Apps Script code + deploy steps.
# Without these, /logs just shows a "not configured yet" notice — nothing else is affected.
ACTIVITY_LOG_WEBHOOK_URL=
# The Sheet's own "Anyone with the link can view" URL — just so /logs has something to link to.
ACTIVITY_LOG_SHEET_VIEW_URL=
